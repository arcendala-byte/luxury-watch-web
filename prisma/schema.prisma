generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

model Product {
  id           Int         @id @default(autoincrement())
  name         String
  brand        String
  slug         String      @unique
  price        Float       
  image        String      @db.Text 
  description  String?
  stock        Int
  
  // Chronos Horological Specifications
  caseMaterial String?
  caseSize     String?
  thickness    String?
  movement     String?     @default("Mechanical Self-winding")
  caliber      String?
  powerReserve String?
  dialColor    String?
  dialPattern  String?
  bracelet     String?
  clasp        String?
  features     String[]    
  curatorNotes String?     @db.Text
  status       String      @default("ACTIVE") 

  // relations
  orderItems   OrderItem[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  name         String?
  
  // Required for Member Registry
  role         String      @default("CLIENT") // ADMIN, CONCIERGE, CLIENT
  status       String      @default("ACTIVE") // ACTIVE, SUSPENDED, PENDING
  
  orders       Order[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Order {
  id           Int         @id @default(autoincrement())
  user         User        @relation(fields: [userId], references: [id])
  userId       Int
  items        OrderItem[]
  total        Float
  status       String      @default("PENDING") 
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id           Int         @id @default(autoincrement())
  order        Order       @relation(fields: [orderId], references: [id])
  orderId      Int
  product      Product     @relation(fields: [productId], references: [id])
  productId    Int
  quantity     Int
  price        Float
}